@page "/settings"
@inject RepoContext Repo
@inject GitHubReleaseService Release

<PageTitle>Settings</PageTitle>

<h1 class="text-2xl font-semibold text-white mb-1">Settings</h1>
<p class="text-sm text-slate-500 mb-6">Resolved paths &amp; environment. Override in <span class="font-mono">admin/appsettings.json</span> (Admin section) or the GODOT / GITHUB_TOKEN env vars.</p>

<div class="rounded-lg border border-edge bg-panel divide-y divide-edge/60 text-sm">
    @Row("Repo root", Repo.RepoRoot, Directory.Exists(Repo.RepoRoot))
    @Row("Games root", Repo.GamesRoot, Directory.Exists(Repo.GamesRoot))
    @Row("Dist", Repo.DistRoot, Directory.Exists(Repo.DistRoot))
    @Row("Schema", Repo.SchemaJson, File.Exists(Repo.SchemaJson))
    @Row("Build script", Repo.BuildAllScript, File.Exists(Repo.BuildAllScript))
    @Row("Python", Repo.Python, null)
    @Row("Godot", Repo.Godot, Repo.GodotExists)
    @Row("Signing key", Repo.SigningKey, Repo.SigningKeyExists)
    @Row("Release repo", Repo.ReleaseRepo, null)
    @Row("GitHub token", Release.HasToken ? "present (env)" : "not set", Release.HasToken)
</div>

@code {
    private RenderFragment Row(string label, string value, bool? ok) => __builder =>
    {
        <div class="flex items-center gap-3 px-4 py-2.5">
            <span class="w-32 text-slate-400">@label</span>
            <span class="flex-1 font-mono text-slate-200 break-all">@value</span>
            @if (ok is not null)
            {
                <span class="@(ok.Value ? "text-emerald-400" : "text-red-400")">@(ok.Value ? "✓" : "✗")</span>
            }
        </div>
    };
}
