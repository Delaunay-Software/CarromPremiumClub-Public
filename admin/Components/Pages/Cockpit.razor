@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.Json.Nodes
@inject GamesTreeService Tree
@inject SchemaService Schema
@inject AssetService Assets
@inject EditSession Edits
@inject PackMap Packs
@inject NavigationManager Nav

<PageTitle>Cockpit</PageTitle>

@if (_root is null)
{
    <div class="px-4 py-3 rounded bg-red-900/50 border border-red-700 text-red-200 text-sm">@_error</div>
}
else
{
    <div class="flex items-center justify-between mb-4">
        <div>
            <h1 class="text-xl font-semibold text-white">Content Cockpit</h1>
            <p class="text-sm text-slate-500">Game → Section → Fields. Edits mark dirty at every level; publish targets only dirty packs.</p>
        </div>
        <div class="flex items-center gap-3">
            @if (_active is not null && Edits.IsNodeDirty(_active))
            {
                <span class="text-xs text-accent">● unsaved</span>
            }
            <button class="px-3 py-2 text-sm rounded bg-accent text-ink font-medium hover:brightness-110 disabled:opacity-40"
                    disabled="@(_active is null || _working is null)" @onclick="Save">Save manifest</button>
            @if (_active is { RelPath: not "" })
            {
                <button class="px-3 py-2 text-sm rounded border border-red-800 text-red-300 hover:bg-red-900/40" @onclick="Delete">Delete game</button>
            }
            <a href="publish" class="px-3 py-2 text-sm rounded border border-edge text-slate-200 hover:bg-edge">Publish…</a>
        </div>
    </div>

    <div class="grid grid-cols-[minmax(220px,1fr)_minmax(160px,0.7fr)_2.2fr] gap-3" style="min-height:70vh">

        <!-- ZONE 1 — GAME -->
        <div class="rounded-lg border border-edge bg-panel flex flex-col overflow-hidden">
            <div class="px-3 py-2 border-b border-edge flex items-center justify-between">
                <span class="text-xs font-semibold uppercase tracking-wide text-slate-400">Game</span>
                <div class="flex items-center gap-2">
                    <button class="text-xs text-slate-400 hover:text-white" @onclick="ToggleAdd" title="new game/group under selection">＋</button>
                    <button class="text-xs text-slate-400 hover:text-white" @onclick="Reload" title="rescan">⟳</button>
                </div>
            </div>
            @if (_showAdd)
            {
                <div class="px-3 py-2 border-b border-edge bg-ink/50 space-y-2">
                    <p class="text-[11px] text-slate-500">New under: <code>@(_active is null || _active.RelPath == "" ? "games/" : _active.RelPath)</code></p>
                    <input class="w-full bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100" placeholder="id (e.g. woodland)" @bind="_newId" />
                    <input class="w-full bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100" placeholder="name (e.g. Woodland)" @bind="_newName" />
                    <select class="w-full bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100" @bind="_newRuleSet">
                        <option value="">group (no rule_set)</option>
                        <option value="icf">icf</option>
                        <option value="casual">casual</option>
                        <option value="arcade">arcade</option>
                    </select>
                    <div class="flex gap-2">
                        <button class="px-2 py-1 text-xs rounded bg-accent text-ink font-medium" @onclick="Create">Create</button>
                        <button class="px-2 py-1 text-xs rounded border border-edge text-slate-300" @onclick="ToggleAdd">Cancel</button>
                    </div>
                </div>
            }
            <div class="overflow-auto flex-1 py-1">
                @foreach (var (node, depth) in _flat)
                {
                    var isActive = _active?.RelPath == node.RelPath;
                    <button class="w-full text-left flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-edge/40 @(isActive ? "bg-edge text-white" : "text-slate-300")"
                            style="padding-left:@(12 + depth * 14)px" @onclick="() => Select(node)">
                        <span class="w-1.5 h-1.5 rounded-full shrink-0 @(Edits.IsNodeDirty(node) ? "bg-accent" : "bg-transparent")"></span>
                        <span class="truncate flex-1">@node.DisplayName</span>
                        @if (node.IsLeaf)
                        {
                            <span class="text-[9px] uppercase px-1.5 py-0.5 rounded bg-accent/20 text-accent">@node.RuleSet</span>
                        }
                        else
                        {
                            <span class="text-[9px] uppercase text-slate-600">grp</span>
                        }
                    </button>
                }
            </div>
        </div>

        <!-- ZONE 2 — SECTION -->
        <div class="rounded-lg border border-edge bg-panel flex flex-col overflow-hidden">
            <div class="px-3 py-2 border-b border-edge">
                <span class="text-xs font-semibold uppercase tracking-wide text-slate-400">Section</span>
            </div>
            <div class="overflow-auto flex-1 py-1">
                @if (_active is null)
                {
                    <p class="px-3 py-2 text-xs text-slate-500">Pick a game.</p>
                }
                else
                {
                    @foreach (var sec in _sections)
                    {
                        var sel = _sectionId == sec.Id;
                        var dirty = _working is not null && Edits.IsAnyKeyDirty(_active, sec.Keys);
                        <button class="w-full text-left flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-edge/40 @(sel ? "bg-edge text-white" : "text-slate-300")"
                                @onclick="() => _sectionId = sec.Id">
                            <span class="w-1.5 h-1.5 rounded-full shrink-0 @(dirty ? "bg-accent" : "bg-transparent")"></span>
                            <span class="truncate flex-1">@sec.Title</span>
                            <span class="text-[10px] text-slate-600">@sec.Fields.Count</span>
                        </button>
                    }
                    <button class="w-full text-left flex items-center gap-2 px-3 py-1.5 text-sm hover:bg-edge/40 @(_sectionId == "_assets" ? "bg-edge text-white" : "text-slate-300")"
                            @onclick='() => _sectionId = "_assets"'>
                        <span class="w-1.5 h-1.5 rounded-full shrink-0 bg-transparent"></span>
                        <span class="truncate flex-1">Assets</span>
                        <span class="text-[10px] text-slate-600">@_assets.Count</span>
                    </button>
                }
            </div>
        </div>

        <!-- ZONE 3 — FIELDS -->
        <div class="rounded-lg border border-edge bg-panel flex flex-col overflow-hidden">
            <div class="px-3 py-2 border-b border-edge flex items-center gap-2">
                <span class="text-xs font-semibold uppercase tracking-wide text-slate-400">Fields</span>
                @if (_active is not null)
                {
                    <span class="text-xs text-slate-500">— @(_active.RelPath == "" ? "games/" : _active.RelPath)/manifest.json</span>
                }
                @if (_msg is not null)
                {
                    <span class="ml-auto text-xs @(_ok ? "text-emerald-300" : "text-red-300")">@_msg</span>
                }
            </div>
            <div class="overflow-auto flex-1 p-3">
                @if (_active is null)
                {
                    <p class="text-sm text-slate-500">Select a game to edit its manifest.</p>
                }
                else if (_working is null)
                {
                    <div class="px-3 py-2 rounded bg-red-900/40 border border-red-700 text-red-200 text-sm">
                        This manifest is malformed JSON — fix it in the raw editor.
                    </div>
                    <textarea class="w-full h-[24rem] mt-3 font-mono text-sm bg-[#0b0c10] border border-edge rounded p-3 text-slate-200"
                              spellcheck="false" @bind="_rawText"></textarea>
                    <button class="mt-2 px-3 py-1.5 text-sm rounded bg-accent text-ink font-medium" @onclick="SaveRaw">Save raw</button>
                }
                else if (_sectionId == "_assets")
                {
                    @AssetsPanel
                }
                else
                {
                    @FieldsPanel
                }
            </div>
        </div>
    </div>
}

@code {
    private ContentNode? _root;
    private ContentNode? _active;
    private string _sectionId = "_basics";
    private JsonObject? _working;
    private IReadOnlyList<SchemaService.Section> _sections = Array.Empty<SchemaService.Section>();
    private readonly List<(ContentNode node, int depth)> _flat = new();
    private IReadOnlyList<AssetEntry> _assets = Array.Empty<AssetEntry>();
    private string? _error, _msg;
    private bool _ok;
    private string _rawText = "";
    private string _uploadDir = "assets/images";
    private bool _showAdd;
    private string _newId = "", _newName = "", _newRuleSet = "";

    protected override void OnInitialized()
    {
        _sections = Schema.Sections();
        Reload();
    }

    private void Reload()
    {
        try
        {
            _root = Tree.Scan();
            _error = null;
            _flat.Clear();
            Flatten(_root, 0);
            // keep selection if still present, else default to first leaf/root
            var keep = _active is null ? null : _flat.FirstOrDefault(f => f.node.RelPath == _active.RelPath).node;
            Select(keep ?? _flat.Select(f => f.node).FirstOrDefault(n => n.IsLeaf) ?? _root);
        }
        catch (Exception e) { _error = e.Message; }
    }

    private void Flatten(ContentNode n, int depth)
    {
        _flat.Add((n, depth));
        foreach (var c in n.Children) Flatten(c, depth + 1);
    }

    private void Select(ContentNode? node)
    {
        _active = node;
        _msg = null;
        if (node is null) { _working = null; return; }
        _working = Edits.Working(node);
        _rawText = _working is null ? Tree.ReadRaw(node.ManifestPath) : "";
        _assets = Assets.List(node);
        if (!_sections.Any(s => s.Id == _sectionId) && _sectionId != "_assets") _sectionId = "_basics";
    }

    private Task OnFieldDirty(string _)
    {
        // A field changed the shared working object; just re-render so dirty rolls up.
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void Save()
    {
        if (_active is null) return;
        var err = Edits.Save(_active);
        _ok = err is null;
        _msg = err ?? "Saved.";
        if (_ok) Reload();   // DisplayName / tree may have changed
    }

    private void SaveRaw()
    {
        if (_active is null) return;
        var err = Tree.SaveRaw(_active.ManifestPath, _rawText);
        _ok = err is null;
        _msg = err ?? "Saved.";
        if (_ok) { Edits.Forget(_active.RelPath); Reload(); }
    }

    // ── Create / delete node ──────────────────────────────────────────────────
    private void ToggleAdd() { _showAdd = !_showAdd; _newId = _newName = _newRuleSet = ""; }

    private void Create()
    {
        try
        {
            var parentRel = _active?.RelPath ?? "";
            Tree.CreateNode(parentRel, _newId, string.IsNullOrEmpty(_newRuleSet) ? null : _newRuleSet, _newName);
            _showAdd = false;
            _ok = true; _msg = $"Created '{_newId}'.";
            Reload();
        }
        catch (Exception e) { _ok = false; _msg = e.Message; }
    }

    private void Delete()
    {
        if (_active is null || _active.RelPath == "") return;
        try
        {
            var gone = _active;
            Tree.DeleteNode(gone);
            Edits.Forget(gone.RelPath);
            _active = null;
            _ok = true; _msg = $"Deleted '{gone.DisplayName}'.";
            Reload();
        }
        catch (Exception e) { _ok = false; _msg = e.Message; }
    }

    // ── Fields panel ──────────────────────────────────────────────────────────
    private RenderFragment FieldsPanel => __builder =>
    {
        var sec = _sections.FirstOrDefault(s => s.Id == _sectionId);
        if (sec is null || _working is null) return;

        if (sec.Id == "_basics")
        {
            <div class="space-y-3">
                @foreach (var f in sec.Fields)
                {
                    <FieldEditor Prop="f" Model="_working" Assets="_assets" GamesRelDir="@GamesRel"
                                 OnDirty="OnFieldDirty" TopKey="@f.Key" />
                }
            </div>
        }
        else
        {
            // A single top-level object section — edit its child properties directly.
            var objField = sec.Fields[0];
            var child = EnsureChild(sec.Keys[0]);
            <div class="flex items-center justify-between mb-2">
                <p class="text-xs text-slate-500">@objField.Description</p>
                @if (_working.ContainsKey(sec.Keys[0]))
                {
                    <button class="text-[11px] text-slate-500 hover:text-red-300" @onclick="() => ClearSection(sec.Keys[0])">clear section</button>
                }
            </div>
            <div class="space-y-3">
                @foreach (var sub in objField.Properties.Values)
                {
                    <FieldEditor Prop="sub" Model="child" Assets="_assets" GamesRelDir="@GamesRel"
                                 OnDirty="OnFieldDirty" TopKey="@sec.Keys[0]" />
                }
            </div>
        }
    };

    private string GamesRel => _active?.RelPath ?? "";

    private JsonObject EnsureChild(string key)
    {
        if (_working![key] is JsonObject existing) return existing;
        var child = new JsonObject();
        _working[key] = child;
        return child;
    }

    private void ClearSection(string key)
    {
        _working?.Remove(key);
        StateHasChanged();
    }

    // ── Assets panel ────────────────────────────────────────────────────────
    private RenderFragment AssetsPanel => __builder =>
    {
        <div class="flex items-end gap-3 mb-3">
            <label class="text-xs text-slate-400">upload into
                <input class="block mt-1 bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100 w-56" @bind="_uploadDir" />
            </label>
            <InputFile OnChange="OnUpload" multiple class="text-sm text-slate-400" />
        </div>
        <div class="rounded-lg border border-edge bg-[#0f1218] divide-y divide-edge/60">
            @if (_assets.Count == 0)
            {
                <div class="px-4 py-3 text-sm text-slate-500">No own assets.</div>
            }
            @foreach (var a in _assets)
            {
                <div class="flex items-center gap-3 px-4 py-2 text-sm">
                    <span class="flex-1 text-slate-200 font-mono truncate">@a.RelPath</span>
                    <span class="text-slate-500 text-xs">@FmtBytes(a.Bytes)</span>
                    <button class="px-2 py-1 rounded hover:bg-red-900/60 text-red-300 text-xs" @onclick="() => DeleteAsset(a)">Delete</button>
                </div>
            }
        </div>
    };

    private async Task OnUpload(InputFileChangeEventArgs e)
    {
        if (_active is null) return;
        int n = 0;
        try
        {
            foreach (var file in e.GetMultipleFiles(50))
            {
                var rel = $"{_uploadDir.Trim('/')}/{file.Name}";
                await using var s = file.OpenReadStream(maxAllowedSize: 512L * 1024 * 1024);
                await Assets.SaveAsync(_active, rel, s);
                n++;
            }
            _assets = Assets.List(_active);
            _ok = true; _msg = $"Uploaded {n} file(s).";
        }
        catch (Exception ex) { _ok = false; _msg = $"Upload failed: {ex.Message}"; }
    }

    private void DeleteAsset(AssetEntry a)
    {
        if (_active is null) return;
        try { Assets.Delete(_active, a.RelPath); _assets = Assets.List(_active); _ok = true; _msg = $"Deleted {a.RelPath}."; }
        catch (Exception ex) { _ok = false; _msg = ex.Message; }
    }

    private static string FmtBytes(long b) =>
        b >= 1 << 20 ? $"{b / (1024.0 * 1024):0.0} MB" : b >= 1 << 10 ? $"{b / 1024.0:0.0} KB" : $"{b} B";
}
