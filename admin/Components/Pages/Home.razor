@page "/"
@rendermode InteractiveServer
@inject GamesTreeService Tree
@inject NavigationManager Nav

<PageTitle>Flavours</PageTitle>

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-semibold text-white">Flavours &amp; Groups</h1>
        <p class="text-sm text-slate-500">The games/ content tree. Leaves carry a rule_set; groups drill in.</p>
    </div>
    <button class="px-3 py-2 text-sm rounded bg-accent text-ink font-medium hover:brightness-110"
            @onclick="@(() => ToggleAdd(""))">+ New at root</button>
</div>

@if (_error is not null)
{
    <div class="mb-4 px-4 py-2 rounded bg-red-900/50 border border-red-700 text-red-200 text-sm">@_error</div>
}

@if (_root is not null)
{
    <div class="rounded-lg border border-edge bg-panel divide-y divide-edge/60">
        @RenderNode(_root, 0)
    </div>
}

@code {
    private ContentNode? _root;
    private string? _error;
    private string? _addParent;   // relpath of the parent the add-form targets (null = closed)
    private string _newId = "", _newName = "";
    private string _newRuleSet = "";  // "" = group

    protected override void OnInitialized() => Reload();

    private void Reload()
    {
        try { _root = Tree.Scan(); _error = null; }
        catch (Exception e) { _error = e.Message; }
    }

    private void ToggleAdd(string parentRel)
    {
        _addParent = _addParent == parentRel ? null : parentRel;
        _newId = _newName = ""; _newRuleSet = "";
    }

    private void Create()
    {
        try
        {
            Tree.CreateNode(_addParent!, _newId, string.IsNullOrEmpty(_newRuleSet) ? null : _newRuleSet, _newName);
            _addParent = null;
            Reload();
        }
        catch (Exception e) { _error = e.Message; }
    }

    private void Delete(ContentNode n)
    {
        try { Tree.DeleteNode(n); Reload(); }
        catch (Exception e) { _error = e.Message; }
    }

    private void Edit(ContentNode n) => Nav.NavigateTo($"/edit/{n.RelPath}");

    private RenderFragment RenderNode(ContentNode n, int depth) => __builder =>
    {
        <div class="flex items-center gap-3 px-4 py-2.5 hover:bg-edge/30" style="padding-left:@(16 + depth * 20)px">
            <span class="text-slate-500 text-xs w-4">@(n.Children.Count > 0 ? "▸" : "·")</span>
            <div class="flex-1 min-w-0">
                <span class="text-slate-100">@n.DisplayName</span>
                <span class="text-slate-500 text-xs ml-2">@(n.RelPath == "" ? "games/" : n.RelPath)</span>
            </div>
            @if (n.IsLeaf)
            {
                <span class="text-[10px] uppercase px-2 py-0.5 rounded bg-accent/20 text-accent border border-accent/40">@n.RuleSet</span>
            }
            else
            {
                <span class="text-[10px] uppercase px-2 py-0.5 rounded bg-slate-700/50 text-slate-400">group</span>
            }
            @if (n.HasPoster)
            {
                <span class="text-[10px] text-slate-500">poster</span>
            }
            <div class="flex gap-1 text-xs">
                <button class="px-2 py-1 rounded hover:bg-edge text-slate-300" @onclick="@(() => Edit(n))">Edit</button>
                <button class="px-2 py-1 rounded hover:bg-edge text-slate-400" @onclick="@(() => ToggleAdd(n.RelPath))">+ Child</button>
                @if (n.RelPath != "")
                {
                    <button class="px-2 py-1 rounded hover:bg-red-900/60 text-red-300" @onclick="@(() => Delete(n))">Delete</button>
                }
            </div>
        </div>
        @if (_addParent == n.RelPath)
        {
            <div class="px-4 py-3 bg-ink/60 border-y border-edge flex flex-wrap items-end gap-3" style="padding-left:@(36 + depth * 20)px">
                <label class="text-xs text-slate-400">id
                    <input class="block mt-1 bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100" @bind="_newId" placeholder="woodland" />
                </label>
                <label class="text-xs text-slate-400">name
                    <input class="block mt-1 bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100" @bind="_newName" placeholder="Woodland" />
                </label>
                <label class="text-xs text-slate-400">rule_set
                    <select class="block mt-1 bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100" @bind="_newRuleSet">
                        <option value="">(group — no rule_set)</option>
                        <option value="icf">icf</option>
                        <option value="casual">casual</option>
                        <option value="arcade">arcade</option>
                    </select>
                </label>
                <button class="px-3 py-1.5 text-sm rounded bg-accent text-ink font-medium" @onclick="Create">Create</button>
                <button class="px-3 py-1.5 text-sm rounded border border-edge text-slate-300" @onclick="@(() => ToggleAdd(n.RelPath))">Cancel</button>
            </div>
        }
        @foreach (var child in n.Children)
        {
            @RenderNode(child, depth + 1)
        }
    };
}
