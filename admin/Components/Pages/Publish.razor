@page "/publish"
@rendermode InteractiveServer
@inject RepoContext Repo
@inject PublishService Publisher
@inject GitService Git
@inject GitHubReleaseService Release

<PageTitle>Sign &amp; Publish</PageTitle>

<h1 class="text-2xl font-semibold text-white mb-1">Sign &amp; Publish</h1>
<p class="text-sm text-slate-500 mb-6">Rebuild + sign packs, commit source, push, and upload the GitHub release.</p>

<!-- Preflight -->
<section class="mb-6 rounded-lg border border-edge bg-panel p-4">
    <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wide mb-3">Preflight</h2>
    <ul class="text-sm space-y-1">
        <li>@Ok(Repo.GodotExists) Godot: <span class="text-slate-400 font-mono">@Repo.Godot</span></li>
        <li>@Ok(Repo.SigningKeyExists) Signing key: <span class="text-slate-400 font-mono">@Repo.SigningKey</span></li>
        <li>@Ok(File.Exists(Repo.BuildAllScript)) Build script</li>
        <li>@Ok(Release.HasToken) GitHub token (GITHUB_TOKEN) for release upload</li>
    </ul>
</section>

<!-- Git status -->
<section class="mb-6 rounded-lg border border-edge bg-panel p-4">
    <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wide">Git — @(_status?.Branch ?? "…")</h2>
        <button class="text-xs px-2 py-1 rounded border border-edge text-slate-300 hover:bg-edge" @onclick="Refresh">Refresh</button>
    </div>
    @if (_status is null)
    {
        <p class="text-sm text-slate-500">Loading…</p>
    }
    else if (_status.Clean)
    {
        <p class="text-sm text-emerald-300">Working tree clean.</p>
    }
    else
    {
        <ul class="text-sm font-mono text-slate-300 space-y-0.5 max-h-40 overflow-auto">
            @foreach (var c in _status.Changes) { <li>@c</li> }
        </ul>
    }
</section>

<!-- Pipeline -->
<section class="mb-6 rounded-lg border border-edge bg-panel p-4 space-y-4">
    <div class="flex flex-wrap items-center gap-3">
        <label class="flex items-center gap-2 text-sm text-slate-300">
            <input type="checkbox" @bind="_skipGen" /> --skip-gen (manifest edits only)
        </label>
        <button class="px-3 py-2 text-sm rounded bg-accent text-ink font-medium disabled:opacity-40"
                disabled="@_busy" @onclick="BuildSign">1 · Build &amp; Sign</button>
    </div>

    <div class="flex flex-wrap items-center gap-3">
        <input class="flex-1 min-w-64 bg-[#0b0c10] border border-edge rounded px-3 py-2 text-sm text-slate-100"
               @bind="_commitMsg" placeholder="commit message" />
        <button class="px-3 py-2 text-sm rounded border border-edge text-slate-200 disabled:opacity-40"
                disabled="@_busy" @onclick="Commit">2 · Commit</button>
        <button class="px-3 py-2 text-sm rounded border border-edge text-slate-200 disabled:opacity-40"
                disabled="@_busy" @onclick="Push">3 · Push</button>
    </div>

    <div class="flex flex-wrap items-center gap-3">
        <input class="w-64 bg-[#0b0c10] border border-edge rounded px-3 py-2 text-sm text-slate-100"
               @bind="_tag" placeholder="release tag" />
        <button class="px-3 py-2 text-sm rounded bg-emerald-700 text-white font-medium disabled:opacity-40"
                disabled="@(_busy || !Release.HasToken)" @onclick="PublishRelease">4 · Upload Release</button>
        @if (!Release.HasToken)
        {
            <span class="text-xs text-amber-400">set GITHUB_TOKEN to enable</span>
        }
    </div>
</section>

<!-- Log -->
<section>
    <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wide">Output</h2>
        <button class="text-xs px-2 py-1 rounded border border-edge text-slate-400 hover:bg-edge" @onclick="@(() => _log.Clear())">Clear</button>
    </div>
    <pre class="h-80 overflow-auto bg-[#0b0c10] border border-edge rounded p-3 text-xs font-mono text-slate-300 whitespace-pre-wrap">@string.Join("\n", _log)</pre>
</section>

@code {
    private GitStatus? _status;
    private bool _busy;
    private bool _skipGen = true;
    private string _commitMsg = "";
    private string _tag = "";
    private readonly List<string> _log = new();

    protected override async Task OnInitializedAsync()
    {
        _tag = PublishService.DefaultTag(DateTimeOffset.Now);
        await Refresh();
    }

    private async Task Refresh()
    {
        try { _status = await Git.StatusAsync(); }
        catch (Exception e) { Log($"git status failed: {e.Message}"); }
    }

    private void Log(string line)
    {
        _log.Add(line);
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task BuildSign()
    {
        var pre = Publisher.Check();
        if (!pre.Ok) { foreach (var p in pre.Problems) Log("⚠ " + p); return; }
        await Run(async () =>
        {
            Log("── Build & sign ──");
            var r = await Publisher.BuildAndSignAsync(_skipGen, Log);
            Log(r.Ok ? "✓ build + sign complete" : $"✗ exited {r.ExitCode}");
        });
    }

    private async Task Commit()
    {
        if (string.IsNullOrWhiteSpace(_commitMsg)) { Log("⚠ commit message required"); return; }
        await Run(async () =>
        {
            await Git.AddAllAsync(Log);
            var r = await Git.CommitAsync(_commitMsg, Log);
            Log(r.Ok ? "✓ committed" : $"✗ commit exited {r.ExitCode}");
            await Refresh();
        });
    }

    private async Task Push()
    {
        await Run(async () =>
        {
            var r = await Git.PushAsync(Log);
            Log(r.Ok ? "✓ pushed" : $"✗ push exited {r.ExitCode}");
        });
    }

    private async Task PublishRelease()
    {
        await Run(async () =>
        {
            Log("── Upload release ──");
            try
            {
                await Release.PublishAsync(_tag, _tag, $"Content release {_tag}", Log);
            }
            catch (Exception e) { Log("✗ " + e.Message); }
        });
    }

    private async Task Run(Func<Task> action)
    {
        _busy = true;
        try { await action(); }
        catch (Exception e) { Log("✗ " + e.Message); }
        finally { _busy = false; await InvokeAsync(StateHasChanged); }
    }

    private static MarkupString Ok(bool ok) =>
        new(ok ? "<span class='text-emerald-400'>✓</span>" : "<span class='text-red-400'>✗</span>");
}
