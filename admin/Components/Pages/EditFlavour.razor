@page "/edit"
@page "/edit/{*RelPath}"
@rendermode InteractiveServer
@inject GamesTreeService Tree
@inject AssetService Assets
@inject NavigationManager Nav

<PageTitle>Edit · @(_node?.DisplayName ?? RelPath)</PageTitle>

<div class="mb-4">
    <a href="/" class="text-sm text-slate-400 hover:text-white">← Flavours</a>
</div>

@if (_node is null)
{
    <div class="px-4 py-3 rounded bg-red-900/50 border border-red-700 text-red-200 text-sm">
        No node at "@RelPath". @_error
    </div>
}
else
{
    <div class="flex items-center justify-between mb-5">
        <div>
            <h1 class="text-2xl font-semibold text-white">@_node.DisplayName</h1>
            <p class="text-sm text-slate-500">@(_node.RelPath == "" ? "games/" : _node.RelPath)/manifest.json</p>
        </div>
        @if (_node.IsLeaf)
        {
            <span class="text-[10px] uppercase px-2 py-0.5 rounded bg-accent/20 text-accent border border-accent/40">@_node.RuleSet</span>
        }
    </div>

    <!-- Manifest editor -->
    <section class="mb-8">
        <div class="flex items-center gap-2 mb-2">
            <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wide">Manifest</h2>
            <div class="flex-1"></div>
            <button class="px-3 py-1.5 text-sm rounded border border-edge text-slate-300 hover:bg-edge" @onclick="Tidy">Tidy JSON</button>
            <button class="px-3 py-1.5 text-sm rounded bg-accent text-ink font-medium hover:brightness-110" @onclick="Save">Save</button>
        </div>
        <textarea class="w-full h-[28rem] font-mono text-sm bg-[#0b0c10] border border-edge rounded p-3 text-slate-200 focus:outline-none focus:border-accent"
                  spellcheck="false" @bind="_text" @bind:event="oninput"></textarea>
        @if (_manifestMsg is not null)
        {
            <div class="mt-2 px-3 py-2 rounded text-sm @(_manifestOk ? "bg-emerald-900/40 border border-emerald-700 text-emerald-200" : "bg-red-900/50 border border-red-700 text-red-200")">
                @_manifestMsg
            </div>
        }
    </section>

    <!-- Assets -->
    <section>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-wide mb-2">Assets</h2>
        <div class="flex items-end gap-3 mb-3">
            <label class="text-xs text-slate-400">upload into
                <input class="block mt-1 bg-panel border border-edge rounded px-2 py-1 text-sm text-slate-100 w-64" @bind="_uploadDir" />
            </label>
            <InputFile OnChange="OnUpload" multiple class="text-sm text-slate-400" />
        </div>
        @if (_assetMsg is not null)
        {
            <div class="mb-3 px-3 py-2 rounded text-sm bg-slate-800/60 border border-edge text-slate-300">@_assetMsg</div>
        }
        <div class="rounded-lg border border-edge bg-panel divide-y divide-edge/60">
            @if (_assets.Count == 0)
            {
                <div class="px-4 py-3 text-sm text-slate-500">No own assets.</div>
            }
            @foreach (var a in _assets)
            {
                <div class="flex items-center gap-3 px-4 py-2 text-sm">
                    <span class="flex-1 text-slate-200 font-mono">@a.RelPath</span>
                    <span class="text-slate-500 text-xs">@FmtBytes(a.Bytes)</span>
                    <span class="text-[10px] text-slate-600">@(a.IsBinary ? "bin" : "text")</span>
                    <button class="px-2 py-1 rounded hover:bg-red-900/60 text-red-300 text-xs" @onclick="@(() => DeleteAsset(a))">Delete</button>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter] public string? RelPath { get; set; }

    private ContentNode? _node;
    private string? _error;
    private string _text = "";
    private string? _manifestMsg;
    private bool _manifestOk;
    private string _uploadDir = "assets/images";
    private IReadOnlyList<AssetEntry> _assets = Array.Empty<AssetEntry>();
    private string? _assetMsg;

    protected override void OnParametersSet() => Load();

    private void Load()
    {
        _manifestMsg = _assetMsg = _error = null;
        try
        {
            var root = Tree.Scan();
            _node = Find(root, (RelPath ?? "").Trim('/'));
            if (_node is not null)
            {
                _text = Tree.ReadRaw(_node.ManifestPath);
                _assets = Assets.List(_node);
            }
        }
        catch (Exception e) { _error = e.Message; }
    }

    private static ContentNode? Find(ContentNode n, string rel)
    {
        if (n.RelPath == rel) return n;
        foreach (var c in n.Children)
            if (Find(c, rel) is { } hit) return hit;
        return null;
    }

    private void Save()
    {
        if (_node is null) return;
        var err = Tree.SaveRaw(_node.ManifestPath, _text);
        _manifestOk = err is null;
        _manifestMsg = err ?? "Saved.";
    }

    private void Tidy()
    {
        try { _text = GamesTreeService.Pretty(_text); _manifestOk = true; _manifestMsg = "Tidied (not yet saved)."; }
        catch (Exception e) { _manifestOk = false; _manifestMsg = e.Message; }
    }

    private async Task OnUpload(InputFileChangeEventArgs e)
    {
        if (_node is null) return;
        int n = 0;
        try
        {
            foreach (var file in e.GetMultipleFiles(50))
            {
                var rel = $"{_uploadDir.Trim('/')}/{file.Name}";
                await using var s = file.OpenReadStream(maxAllowedSize: 512L * 1024 * 1024);
                await Assets.SaveAsync(_node, rel, s);
                n++;
            }
            _assets = Assets.List(_node);
            _assetMsg = $"Uploaded {n} file(s).";
        }
        catch (Exception ex) { _assetMsg = $"Upload failed: {ex.Message}"; }
    }

    private void DeleteAsset(AssetEntry a)
    {
        if (_node is null) return;
        try { Assets.Delete(_node, a.RelPath); _assets = Assets.List(_node); _assetMsg = $"Deleted {a.RelPath}."; }
        catch (Exception ex) { _assetMsg = ex.Message; }
    }

    private static string FmtBytes(long b) =>
        b >= 1 << 20 ? $"{b / (1024.0 * 1024):0.0} MB" : b >= 1 << 10 ? $"{b / 1024.0:0.0} KB" : $"{b} B";
}
